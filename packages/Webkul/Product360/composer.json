{
    "name": "bagisto/laravel-product360",
    "description": "360-degree product viewer module for Bagisto",
    "license": "MIT",
    "authors": [
        {
            "name": "Bagisto",
            "email": "support@bagisto.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "Webkul\\Product360\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkul\\Product360\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\Product360\\Providers\\Product360ServiceProvider"
            ],
            "aliases": {}
        }
    },
    "minimum-stability": "dev"
}
